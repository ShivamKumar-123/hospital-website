# Copy this file to .env and fill in your values.
# Only keys prefixed with VITE_ are exposed to the client.

# ---------- Admin (hospital staff) ----------
VITE_ADMIN_NAME=Hospital Admin
VITE_ADMIN_EMAIL=admin@hospital.com
VITE_ADMIN_PASSWORD=admin123

# ---------- Demo patient (for showcase / first login) ----------
VITE_DEMO_USER_NAME=Demo Patient
VITE_DEMO_USER_EMAIL=patient@hospital.com
VITE_DEMO_USER_PASSWORD=patient123
VITE_DEMO_USER_PHONE=+1 555 0100

# ---------- App identity ----------
VITE_HOSPITAL_NAME=MediCare+ Hospital
VITE_EMERGENCY_PHONE=+1 (800) 911-0000

# ---------- Deployment ----------
# Public URL where this site will be served — used by SEO meta, canonical
# links, sitemap and Open Graph tags. Set this in Vercel project settings.
VITE_SITE_URL=https://your-domain.vercel.app
