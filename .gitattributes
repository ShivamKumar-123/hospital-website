# Normalize all text files to LF line endings.
# This is the de-facto standard for Node/web projects and silences the
# "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicit text rules (belt-and-braces for editors that guess wrong)
*.js     text eol=lf
*.jsx    text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.svg    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
.env*    text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf

# Windows-only scripts keep CRLF (they break with LF)
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary files — never touch
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.mp4    binary
*.webm   binary
